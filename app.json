{
  "expo": {
    "name": "CatTracker",
    "slug": "CatTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cattracker",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "top.dramavision.cattracker",
      "buildNumber": "14",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "top.dramavision.cattracker"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-sqlite",
      "expo-localization",
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eb82af28-f730-4cd0-abbb-a0c924139702"
      }
    },
    "owner": "maruipp"
  }
}
